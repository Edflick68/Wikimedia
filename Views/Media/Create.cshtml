@model Wikimedia.Models.Media
@{
    ViewBag.Action = "Create";
    Html.RenderPartial("MediaForm");
}

@section Scripts { 
    <script>$(() => {
            initFormValidation();
    addConflictValidation("/Media/CheckConflict", 'YoutubeId', 'submit');
    $("#YoutubeId").on("change", function () {
        let youtubeId = $("#YoutubeId").val().trim();
        if (youtubeId.indexOf("=") > -1)
            youtubeId = $("#YoutubeId").val().split("=")[1];
        $("#YoutubeId").val(youtubeId);
        $("#previewThumbnail").attr("src", `https://img.youtube.com/vi/${youtubeId}`)
    })
        })</script>
}