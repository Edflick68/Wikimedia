using Wikimedia.Models;
using Wikimedia.DAL;
@{
    string controller = HttpContext.Current.Request.RequestContext.RouteData.Values["controller"].ToString().ToLower();
    string action = HttpContext.Current.Request.RequestContext.RouteData.Values["action"].ToString().ToLower();
    bool search = Session["Search"] != null ? (bool)Session["Search"] : false;
    string searchString = Session["SearchString"] != null ? (string)Session["SearchString"] : "";
    int currentMediaId = Session["CurrentMediaId"] != null ? (int)Session["CurrentMediaId"] : 0;
    string currentMediaTitle = Session["CurrentMediaTitle"] != null ? (string)Session["CurrentMediaTitle"] : "";
    string selectedCategory = Session["CurrentSelectedCategory"] != null ? (string)Session["CurrentSelectedCategory"] : "";
    bool sortByTitle = Session["SortByTitle"] != null ? (bool)Session["SortByTitle"] : true;
    bool sortByDate = Session["SortByDate"] != null ? (bool)Session["SortByDate"] : true;
    bool sortByLikes = Session["SortByLikes"] != null ? (bool)Session["SortByLikes"] : true;
    string checkSortByTitle = sortByTitle ? "fa-check" : "";
    string checkSortByDate = sortByDate ? "" : "fa-check";
    string checkSortByLikes = sortByLikes ? "" : "fa-check";
    var MediaList = (List<Wikimedia.Models.Media>)Session["Media"];
    bool SearchAscending = Session["SortAscending"] != null ? (bool)Session["SortAscending"] : true;
    var currentMedia = currentMediaId > 0 ? DB.Medias.Get(currentMediaId) : null;
    bool userConnected = Models.User.ConnectedUser != null;
    bool userIsAdmin = userConnected ? Models.User.ConnectedUser.IsAdmin : false;
    bool userCanWrite = userConnected ? Models.User.ConnectedUser.CanWrite : false;
    string index = RouteConfig.DefaultAction();
}

<div class="section roundedBorder">
    <div class="headerMenu">
        <a class="siteIcon" href="/media/list"></a>
        @switch (action)
        {
            case "login":
                <div class="pageTitle">Connexion</div>
                break;
            case "subscribe":
                <div class="pageTitle">S'inscrire</div>
                <div id="mainMenuPanel" class="menu">
                    <i class="cmdIcon submitCmd fa fa-circle-check" title="Soumettre" onclick="document.getElementById('submit').click()"></i>
                    <a class="cmdIcon fa fa-square-xmark" title="Annuler" onclick="history.back()"></a>
                </div>
                break;
            case "editprofil":
                <div id="mainMenuPanel" class="menu">
                    <i class="cmdIcon submitCmd fa fa-circle-check" title="Soumettre" onclick="document.getElementById('submit').click()"></i>
                    <a class="cmdIcon fa fa-square-xmark" title="Annuler" onclick="history.back()"></a>
                </div>
                break;
            case "list":
                <div class="pageTitle">Wikimedia</div>
                <div id="mainMenuPanel" class="menu">
                    @if (userCanWrite)
                    {
                        <a href="/@controller/Create" class="cmdIcon fa fa-circle-plus" title="Ajouter..."></a>
                    }
                    @if (SearchAscending)
                    {
                        <a href="/@controller/ToggleSort" id="cmdToggleSearch" class="cmdIcon fa fa-arrow-down-short-wide" title="Tri ascendant..."></a>
                    }
                    else
                    {
                        <a href="/@controller/ToggleSort" id="cmdToggleSearch" class="cmdIcon fa fa-arrow-up-wide-short" title="Tri descendant..."></a>
                    }
                    <div id="menu" class="dropdown ms-auto">
                        <div data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="cmdIcon fa fa-bars" title="Menu"></i>
                        </div>
                        <div class="dropdown-menu noselect" id="DDMenu">
                            <div class="dropdown-item item-layout">
                                <i class="menuIcon fa fa-address-card"></i>
                                <a href="/Accounts/EditProfil">Profil...</a>
                            </div>
                            <div class="dropdown-item item-layout">
                                <i class="menuIcon fa fa-sign-out"></i>
                                <a href="/Accounts/Login">Déconnexion...</a>
                            </div>
                            @if (userIsAdmin)
                            {
                                <div class="dropdown-divider"></div>

                                <div class="dropdown-item item-layout">
                                    <i class="menuIcon fa fa-users"></i>
                                    <a href="/Accounts/ManageUsers">
                                        Gestion des usagers...
                                    </a>
                                </div>
                                <div class="dropdown-item item-layout">
                                    <i class="menuIcon fa fa-calendar-days"></i>
                                    <a href="/Accounts/LoginsJournal">
                                        Historique de connexions...
                                    </a>
                                </div>
                                <div class="dropdown-item item-layout">
                                    <i class="menuIcon fa fa-gear"></i>
                                    <a href="/Accounts/EventsJournal">
                                        Journal d'activités...
                                    </a>
                                </div>
                            }

                            <div class="dropdown-divider"></div><div class="dropdown-item item-layout">
                                <i class="menuIcon fa @checkSortByTitle"></i>
                                <a href="/@controller/SortByTitle">Trier par titre</a>
                            </div>
                            <div class="dropdown-item item-layout">
                                <i class="menuIcon fa @checkSortByDate"></i>
                                <a href="/@controller/SortByDate">Trier par date</a>
                            </div>
                            <div class="dropdown-item item-layout">
                                <i class="menuIcon fa @checkSortByDate"></i>
                                <a href="/@controller/SortByLikes">Trier par j'aime</a>
                            </div>

                            <div class="dropdown-divider"></div>
                            <div class="dropdown-item item-layout">
                                <i class="menuIcon fa fa-info-circle"></i>
                                <a href="/@controller/About">À propos...</a>
                            </div>
                        </div>
                    </div>
                </div>
                break;
            case "details":
                <div class="pageTitle">Détails</div>
                <div id="mainMenuPanel" class="menu">
                    if(@currentMedia != null)
                    {
                    <span class="likeCount" title="@string.Join(",",currentMedia.Likes.Select(l => DB.Users.Get(l.UserId).Name))">@currentMedia.Likes.Count</span>
                    <i class="cmdIcon fa-regular fa-thumbs-up toggleLikeCmd @(currentMedia.Likes.Any(l => l.UserId == Models.User.ConnectedUser.Id) ? "fa-solid" : "fa-regular")"
                       title="J'aime"
                       onclick="toggleLike(@currentMedia.Id)"></i>
                    }
                    <a href="/@controller/Edit/@currentMediaId" class="cmdIcon fa fa-pen-to-square" title="Modifier..."></a>
                    <i class="cmdIcon fa fa-trash-can"
                       title="Effacer"
                       onclick="bootbox.confirm(`<b style=color:red>Effacer le contact : </b><h3>@currentMediaTitle?</h3>`, function(result){ if (result) window.location = '/@controller/Delete'; })">
                    </i>
                    <a href="/@controller/List" class="cmdIcon fa fa-square-xmark" title="retour"></a>
                </div>
                break;
            case "create":
                <div class="pageTitle">Ajout</div>
                <div id="mainMenuPanel" class="menu">
                    <i class="cmdIcon submitCmd fa fa-circle-check" title="Soumettre" onclick="document.getElementById('submit').click()"></i>
                    <a href="/@controller/List" class="cmdIcon fa fa-square-xmark" title="Annuler"></a>
                </div>
                break;
            case "edit":
                <div class="pageTitle">Modification</div>
                <div id="mainMenuPanel" class="menu">
                    <i class="cmdIcon submitCmd fa fa-circle-check" title="Soumettre" onclick="document.getElementById('submit').click()"></i>
                    <a href="/@controller/Details/@currentMediaId" class="cmdIcon fa fa-square-xmark" title="Annuler"></a>
                </div>
                break;
            case "about":
                <div class="pageTitle">À propos</div>
                <div id="mainMenuPanel" class="menu">
                    <a href="/@controller/List" class="cmdIcon fa fa-square-xmark" title="Retour"></a>
                </div>
                break;
            case "loginsjournal":
            case "eventsjournal":
            case "manageusers":
                <div id="mainMenuPanel" class="menu">
                    <a href="@index" class="cmdIcon fa fa-square-xmark" title="Retour"></a>
                </div>
                break;
        }

    </div>
</div>
@if (action == "list" && search)
{
    <div class="flex">
        <input type="search" id="searchInput" class="section roundedBorder flexItem" value="@searchString" placeholder="Recherche...">
        <div id="CategorySelectPanel" class="flexItem">

        </div>

    </div>
}


